# Local dev — Rserve websocket URL (direct to Rserve on port 6311)
VITE_RSERVE_HOST=http://127.0.0.1:6311

# Production (Docker/Railway) — set on the container, not in the frontend build:
# PORT=8080                              # Railway sets this automatically
# HOSTNAME=https://vit.example.railway.app  # → wss://vit.example.railway.app/rserve
# RSERVE_PATH=/rserve                    # suffix when using HOSTNAME (default)
# RSERVE_HOST=/rserve                    # override WebSocket URL/path entirely
